# Copie ce fichier en ".env" et remplis tes valeurs.
# Le fichier .env ne doit jamais etre partage ni commite (il contient tes cles).

# === Bright Data ===
# Cle API generee dans ton tableau de bord Bright Data (zone Web Unlocker)
BRIGHTDATA_TOKEN=colle_ta_cle_brightdata_ici
# Nom de ta zone Web Unlocker (souvent web_unlocker1)
BRIGHTDATA_ZONE=web_unlocker1

# === Email (Resend) ===
# Cle API generee sur resend.com
RESEND_API_KEY=colle_ta_cle_resend_ici
# Expediteur : onboarding@resend.dev fonctionne pour tester sans domaine.
# Pour un usage durable, verifie ton domaine chez Resend et mets alerte@tondomaine.fr
ALERTE_FROM=onboarding@resend.dev
# Ton adresse de reception (plusieurs possibles, separees par des virgules)
ALERTE_TO=rayan@exemple.fr
